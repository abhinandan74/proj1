generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Meetup {
  id          Int      @id @default(autoincrement())
  title       String
  date        String
  time        String   @default("10:00 AM")
  description String
  location    String   @default("Virtual Event")
  capacity    Int      @default(100)
  category    String   @default("Tech")
  image       String   @default("https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80")
  createdAt   DateTime @default(now())
  rsvps       Rsvp[]
}

model Rsvp {
  id        Int      @id @default(autoincrement())
  meetupId  Int
  name      String
  email     String
  phone     String?
  company   String?
  status    String   @default("attending")
  createdAt DateTime @default(now())
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
}
